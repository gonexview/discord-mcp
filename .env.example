SPRING_PROFILES_ACTIVE=http
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=OPTIONAL_DEFAULT_SERVER_ID

# API Key Auth: generate with `openssl rand -hex 32`, then hash with `echo -n "<key>" | sha256sum`
# Put the SHA256 hash here. The raw key goes into Claude Teams MCP config as Bearer token.
DISCORD_MCP_API_KEY_HASH=SHA256_HEX_HASH_OF_YOUR_API_KEY
